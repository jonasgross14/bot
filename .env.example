# ============================================================
#  Auction-Theory-Bot - Beispiel-Konfiguration
#  Kopiere diese Datei zu .env und passe die Werte an.
# ============================================================

# --- Markt / Pair ---
SYMBOL=BTC/USDT
SPOT_SYMBOL=BTC/USDT
PERP_SYMBOL=BTC/USDT:USDT
EXCHANGE=binance
MARKET_TYPE=future          # spot oder future

# --- Timeframes ---
TIMEFRAMES=5m,15m,30m,1h,4h,1d
PRIMARY_TIMEFRAME=30m
PROFILE_TIMEFRAME=30m
PROFILE_LOOKBACK_DAYS=1

# --- Volume Profile ---
VP_NUM_BINS=80
VALUE_AREA_PERCENT=0.70
HVN_THRESHOLD=1.5
LVN_THRESHOLD=0.4

# --- Market Profile ---
TPO_SIZE_MINUTES=30
INITIAL_BALANCE_PERIODS=2
SESSION_START_UTC=00:00
SESSION_LENGTH_HOURS=24

# --- Orderflow ---
OI_LOOKBACK_MINUTES=60
CVD_LOOKBACK_MINUTES=60

# --- Modus ---
MODE=live                   # live oder backtest
LIVE_INTERVAL_SECONDS=300
BACKTEST_START=2024-01-01
BACKTEST_END=2024-01-07

# --- API-Keys (fuer Public-Daten meist nicht noetig) ---
API_KEY=
API_SECRET=

# --- Output ---
OUTPUT_DIR=./output
SAVE_TEXT=true
SAVE_CHART=true
CHART_ENGINE=matplotlib     # matplotlib oder plotly

# --- Logging ---
LOG_LEVEL=INFO
